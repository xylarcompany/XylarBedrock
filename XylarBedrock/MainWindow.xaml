<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:XylarBedrock.Properties"
        xmlns:viewModels="clr-namespace:XylarBedrock.ViewModels"
        xmlns:local="clr-namespace:XylarBedrock"
        xmlns:com="clr-namespace:JemExtensions.WPF.Behaviours;assembly=JemExtensions"
        xmlns:controls="clr-namespace:XylarBedrock.Pages.General"
        xmlns:pages="clr-namespace:XylarBedrock.Pages"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        x:Class="XylarBedrock.MainWindow"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
        mc:Ignorable="d"
        Title="{x:Static local:App.DisplayName}"
        Height="700"
        Width="1016"
        MinWidth="1016"
        MinHeight="700"
        Foreground="{x:Null}"
        Background="{DynamicResource Background.Primary}"
        WindowStyle="None"
        ResizeMode="CanResize"
        Initialized="Window_Initialized"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        SizeChanged="Window_SizeChanged"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="7"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TrafficButtonBaseStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#FFED6B5F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ButtonScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Ellipse x:Name="ButtonSurface"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="#26000000"
                                     StrokeThickness="1"/>
                            <TextBlock x:Name="ButtonGlyph"
                                       Text="{TemplateBinding Content}"
                                       Foreground="#88171717"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                       Opacity="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonGlyph" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonGlyph" Property="Opacity" Value="1"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.12"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.12"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.92"
                                                         Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.92"
                                                         Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.12"
                                                         Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.12"
                                                         Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrafficCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TrafficButtonBaseStyle}">
            <Setter Property="Background" Value="#FFFF5F57"/>
            <Setter Property="Content" Value="×"/>
        </Style>

        <Style x:Key="TrafficMinButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TrafficButtonBaseStyle}">
            <Setter Property="Background" Value="#FFFEBB2E"/>
            <Setter Property="Content" Value="−"/>
        </Style>

        <Style x:Key="TrafficMaxButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TrafficButtonBaseStyle}">
            <Setter Property="Background" Value="#FF28C840"/>
            <Setter Property="Content" Value="+"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource Background.Primary}"
          MouseDown="Window_MouseDown">
        <Border x:Name="WindowFrameBorder"
                Margin="0"
                CornerRadius="14"
                BorderBrush="Transparent"
                BorderThickness="0"
                Background="{DynamicResource Background.Primary}">
            <Border.RenderTransform>
                <ScaleTransform x:Name="WindowFrameScaleTransform"
                                ScaleX="1"
                                ScaleY="1"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FF171717"
                        BorderBrush="#26000000"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="14,0,0,0">
                            <Button Style="{StaticResource TrafficCloseButtonStyle}"
                                    Click="CloseButton_Click"
                                    ToolTip="Close"/>
                            <Button Style="{StaticResource TrafficMinButtonStyle}"
                                    Click="MinimizeButton_Click"
                                    ToolTip="Minimize"/>
                            <Button Style="{StaticResource TrafficMaxButtonStyle}"
                                    Click="MaximizeButton_Click"
                                    ToolTip="Maximize"/>
                        </StackPanel>

                        <TextBlock Text="{x:Static local:App.DisplayName}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFF0F0F0"
                                   FontSize="14"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Background="{DynamicResource Background.Primary}">
                    <Frame x:Name="MainFrame"
                           IsEnabled="{Binding Source={x:Static viewModels:MainViewModel.Default},Path=MainFrame_isEnabled, Mode=OneWay}"
                           com:DisableNavigation.Disable="True"
                           Focusable="False"
                           Margin="0"
                           NavigationUIVisibility="Hidden"
                           Panel.ZIndex="-1">
                        <Frame.Content>
                            <pages:MainPage x:Name="MainPage"/>
                        </Frame.Content>
                    </Frame>
                    <Frame x:Name="OverlayFrame"
                           IsEnabled="{Binding Source={x:Static viewModels:MainViewModel.Default},Path=OverlayFrame_isEnabled, Mode=OneWay}"
                           Content="{Binding Source={x:Static viewModels:MainViewModel.Default},Path=OverlayFrame_Content, Mode=TwoWay}"
                           com:DisableNavigation.Disable="True"
                           Focusable="False"
                           Margin="0"
                           Grid.ColumnSpan="2"
                           NavigationUIVisibility="Hidden"
                           Panel.ZIndex="-2"/>
                    <Frame x:Name="ErrorFrame"
                           Content="{Binding Source={x:Static viewModels:MainViewModel.Default},Path=ErrorFrame_Content, Mode=TwoWay}"
                           com:DisableNavigation.Disable="True"
                           Focusable="False"
                           Margin="0"
                           Grid.ColumnSpan="2"
                           NavigationUIVisibility="Hidden"
                           Panel.ZIndex="-3"/>
                    <controls:Component_UpdateButton Visibility="Collapsed"
                                                     Margin="0,-75,5,0"
                                                     Grid.ColumnSpan="2"
                                                     Panel.ZIndex="-4"
                                                     x:Name="UpdateButton"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Top"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
