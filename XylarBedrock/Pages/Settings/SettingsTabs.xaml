<Page x:Class="XylarBedrock.Pages.Settings.SettingsTabs"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:com="clr-namespace:JemExtensions.WPF.Behaviours;assembly=JemExtensions"
      Loaded="Page_Loaded"
      mc:Ignorable="d"
      Title="{DynamicResource SettingsTab_Title}"
      Background="{DynamicResource Background.Secondary}">
    <Grid Background="{DynamicResource Background.Primary}" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="84"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Background.Primary}"
                BorderBrush="Transparent"
                BorderThickness="0">
            <Grid>
                <Label Content="{DynamicResource SettingsTab_Title}"
                       Margin="12,27,600,0"
                       Style="{DynamicResource TabTitle}"/>

                <StackPanel HorizontalAlignment="Left"
                            Height="35"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            Margin="5,49,0,0">
                    <ToggleButton x:Name="GeneralButton"
                                  Width="Auto"
                                  Click="ButtonManager"
                                  Content="{DynamicResource SettingsTab_GeneralButton}"
                                  Style="{DynamicResource ToolbarButton}"
                                  IsChecked="True">
                        <ToggleButton.ToolTip>
                            <ToolTip Content="{DynamicResource SettingsTab_GeneralButton}"/>
                        </ToggleButton.ToolTip>
                    </ToggleButton>
                    <ToggleButton x:Name="AboutButton"
                                  Width="Auto"
                                  Click="ButtonManager"
                                  Content="{DynamicResource SettingsTab_AboutButton}"
                                  Style="{DynamicResource ToolbarButton}">
                        <ToggleButton.ToolTip>
                            <ToolTip Content="{DynamicResource SettingsTab_AboutButton}"/>
                        </ToggleButton.ToolTip>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Background="{DynamicResource Background.Tertiary}"/>

        <Frame Grid.Row="1"
               x:Name="SettingsScreenFrame"
               ClipToBounds="True"
               Focusable="False"
               NavigationUIVisibility="Hidden"
               com:DisableNavigation.Disable="True"/>
    </Grid>
</Page>
