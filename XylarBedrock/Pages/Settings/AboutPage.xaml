<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:root="clr-namespace:XylarBedrock"
      x:Class="XylarBedrock.Pages.Settings.AboutPage"
      mc:Ignorable="d"
      d:DesignHeight="728"
      d:DesignWidth="820"
      Title="AboutPage"
      Initialized="Page_Initialized"
      MinWidth="728"
      MinHeight="525"
      Background="{DynamicResource Background.Tertiary}">
    <Page.Resources>
        <Style x:Key="SectionBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Style>

        <Style x:Key="SectionText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource Background.Tertiary}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,22"
                        MaxWidth="1120"
                        HorizontalAlignment="Center">
                <Border BorderBrush="#FF484848"
                        BorderThickness="1"
                        Margin="0,0,0,16">
                    <Grid Height="224">
                        <Grid.Background>
                            <ImageBrush TileMode="Tile"
                                        Viewport="0,0,800,400"
                                        ViewportUnits="Absolute"
                                        ImageSource="/XylarBedrock;component/resources/images/bg/stone_texture.png"/>
                        </Grid.Background>

                        <Border Background="#C6141414"/>

                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,18,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{x:Static root:App.DisplayName}"
                                           Foreground="White"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#FFDDF6E6"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans">
                                    <Run Text="{DynamicResource AboutPage_VersionLabel}"/>
                                    <Run Text="{x:Static root:App.Version}"/>
                                </TextBlock>
                                <TextBlock Margin="0,12,0,0"
                                           Text="{DynamicResource AboutPage_IntroText}"
                                           Style="{StaticResource SectionText}"/>
                                <TextBlock Margin="0,14,0,0"
                                           Text="{DynamicResource AboutPage_QuoteText}"
                                           Foreground="White"
                                           FontSize="15"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                                <TextBlock Margin="0,10,0,0"
                                           Text="{DynamicResource AboutPage_Signature}"
                                           Foreground="#9FD3FF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#B30F0F0F"
                                    BorderBrush="#FF404040"
                                    BorderThickness="1"
                                    Padding="14">
                                <Image Source="/XylarBedrock;component/resources/images/credits/xylarinc.png"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="{DynamicResource AboutPage_LinksTitle}"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource AboutPage_LinksText}"
                                       Style="{StaticResource SectionText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{DynamicResource AboutPage_DiscordButton}"
                                    Tag="https://discord.gg/CQ6Et3Kws7"
                                    Click="Button_Click"
                                    Style="{DynamicResource DialogButton_Green}"
                                    Height="32"/>
                            <Button Margin="10,0,0,0"
                                    x:Name="CheckForUpdatesButton"
                                    Click="CheckForUpdatesButton_Click"
                                    Content="{DynamicResource AboutPage_CheckUpdatesButton}"
                                    Style="{DynamicResource DialogButton}"
                                    Height="32"/>
                            <Button Margin="10,0,0,0"
                                    x:Name="ForceUpdateButton"
                                    Click="ForceUpdateButton_Click"
                                    Content="{DynamicResource AboutPage_GetUpdatesButton}"
                                    Style="{DynamicResource DialogButton_Green}"
                                    Height="32"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="{DynamicResource AboutPage_OriginTitle}"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource AboutPage_OriginText}"
                                       Style="{StaticResource SectionText}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="{DynamicResource AboutPage_GithubButton}"
                                Tag="https://github.com/BedrockLauncher/BedrockLauncher"
                                Click="Button_Click"
                                Style="{DynamicResource DialogButton}"
                                Height="32"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource AboutPage_TeamTitle}"
                                   Style="{StaticResource SectionTitle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{DynamicResource AboutPage_TeamText}"
                                   Style="{StaticResource SectionText}"/>
                    </StackPanel>
                </Border>

                <WrapPanel Margin="0,0,0,16"
                           HorizontalAlignment="Center">
                    <Border Width="286"
                            Margin="0,0,16,16"
                            Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <Border Background="#FF1B1B1B"
                                    BorderBrush="#FF404040"
                                    BorderThickness="1">
                                <Image Height="138"
                                       Source="/XylarBedrock;component/resources/images/credits/mrmariix.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource AboutPage_MrmariixRole}"
                                       Foreground="#FFA7D9B8"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Mrmariix"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource AboutPage_MrmariixText}"
                                       Style="{StaticResource SectionText}"/>
                        </StackPanel>
                    </Border>

                    <Border Width="286"
                            Margin="0,0,16,16"
                            Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <Border Background="#FF1B1B1B"
                                    BorderBrush="#FF404040"
                                    BorderThickness="1">
                                <Image Height="138"
                                       Source="/XylarBedrock;component/resources/images/credits/SasyIsCool.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource AboutPage_SasyRole}"
                                       Foreground="#FFA7D9B8"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="SasyIsCool"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource AboutPage_SasyText}"
                                       Style="{StaticResource SectionText}"/>
                        </StackPanel>
                    </Border>

                    <Border Width="238"
                            Margin="0,0,0,16"
                            Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <Border Background="#FF1B1B1B"
                                    BorderBrush="#FF404040"
                                    BorderThickness="1">
                                <Image Height="96"
                                       Source="/XylarBedrock;component/resources/images/credits/the_red_shadow.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource AboutPage_RedShadowRole}"
                                       Foreground="#FFA7D9B8"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="The Red Shadow"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource AboutPage_RedShadowText}"
                                       Style="{StaticResource SectionText}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="{DynamicResource AboutPage_CreditsTitle}"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource AboutPage_CreditsText}"
                                       Style="{StaticResource SectionText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,6,0,0">
                                <Border Width="128"
                                        Height="70"
                                        Background="#FF1B1B1B"
                                        BorderBrush="#FF404040"
                                        BorderThickness="1"
                                        Padding="12">
                                    <Image Source="/XylarBedrock;component/resources/images/credits/microsoft_logo.png"
                                           Stretch="Uniform"/>
                                </Border>
                                <Border Width="128"
                                        Height="70"
                                        Margin="12,0,0,0"
                                        Background="#FF1B1B1B"
                                        BorderBrush="#FF404040"
                                        BorderThickness="1"
                                        Padding="12">
                                    <Image Source="/XylarBedrock;component/resources/images/credits/mojang_logo.png"
                                           Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
