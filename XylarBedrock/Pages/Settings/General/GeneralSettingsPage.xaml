<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:properties="clr-namespace:XylarBedrock.Properties"
      xmlns:viewModels="clr-namespace:XylarBedrock.ViewModels"
      xmlns:wincontrols="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
      xmlns:con="clr-namespace:XylarBedrock.Pages.Settings.General.Components"
      x:Class="XylarBedrock.Pages.Settings.General.GeneralSettingsPage"
      mc:Ignorable="d"
      d:DesignHeight="828"
      d:DesignWidth="720"
      Title="GeneralSettingsPage"
      Loaded="Page_Loaded"
      Initialized="Page_Initialized"
      MinWidth="728"
      MinHeight="525"
      Background="{DynamicResource Background.Secondary}">
    <Page.Resources>
        <wincontrols:BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SettingsCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#1D2329"/>
            <Setter Property="BorderBrush" Value="#313C46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="SettingsCardTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>

        <Style x:Key="SettingsCardText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#B7C8D6"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,24,24,30">
                <Border Style="{StaticResource SettingsCard}" Background="#1E2A33" BorderBrush="#3A5568">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Official Minecraft for Windows only" Style="{StaticResource SettingsCardTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="XylarBedrock now launches only the original Minecraft for Windows app. Install it from Microsoft Store, even with the free trial, before using the launcher."
                                       Style="{StaticResource SettingsCardText}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="No beta, preview, custom APPX imports, or extra version channels are shown anymore."
                                       Style="{StaticResource SettingsCardText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                            <Button Content="Join Xylar Inc. Discord"
                                    Click="OpenDiscordButton_Click"
                                    Style="{DynamicResource DialogButton_Green}"
                                    MinWidth="180"
                                    Height="34"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Language and theme" Style="{StaticResource SettingsCardTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Choose how XylarBedrock looks and which language it should use."
                                       Style="{StaticResource SettingsCardText}"/>

                            <TextBlock Margin="0,16,0,6" Text="{DynamicResource GeneralSettingsScreen_LanguageSubtitle}" Style="{StaticResource SettingsCardText}" Foreground="White"/>
                            <con:LanguageCombobox HorizontalAlignment="Left"
                                                  FontSize="14"
                                                  Padding="10,4,5,3"
                                                  x:Name="LanguageCombobox"/>

                            <TextBlock Margin="0,16,0,6" Text="{DynamicResource GeneralSettingsScreen_ThemeSubtitle}" Style="{StaticResource SettingsCardText}" Foreground="White"/>
                            <con:ThemeCombobox HorizontalAlignment="Left"
                                               FontSize="14"
                                               Padding="10,4,5,3"
                                               x:Name="ThemeCombobox"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Launcher behavior" Style="{StaticResource SettingsCardTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Only the options that still make sense for the official Microsoft Store release stay here."
                                       Style="{StaticResource SettingsCardText}"/>

                            <StackPanel Margin="0,16,0,0">
                                <CheckBox Style="{StaticResource SettingsCheckBox}"
                                          IsChecked="{Binding Source={x:Static properties:LauncherSettings.Default}, Path=KeepLauncherOpen}"
                                          IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}"
                                          x:Name="keepLauncherOpenCheckBox"
                                          Click="Checkbox_Click"
                                          Content="{DynamicResource GeneralSettingsScreen_KeepLauncherOpen}"/>

                                <CheckBox Style="{StaticResource SettingsCheckBox}"
                                          IsChecked="{Binding Source={x:Static properties:LauncherSettings.Default}, Path=AnimatePageTransitions}"
                                          Click="Checkbox_Click"
                                          Content="{DynamicResource GeneralSettingsScreen_AnimateTransitions}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel>
                        <TextBlock Text="Storage and restart" Style="{StaticResource SettingsCardTitle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="Keep your current folder setup or move XylarBedrock data somewhere else. Changes here require a restart."
                                   Style="{StaticResource SettingsCardText}"/>

                        <CheckBox x:Name="portableModeCheckBox"
                                  Margin="0,18,0,0"
                                  Click="useFixedInstallLocation_Click"
                                  Style="{StaticResource SettingsCheckBox}"
                                  Content="{DynamicResource GeneralSettingsScreen_PathOptions_PortableMode_Text}"/>

                        <TextBlock Margin="0,12,0,6"
                                   Text="{DynamicResource GeneralSettingsScreen_PathOptions_PathSubtitle_Text}"
                                   Style="{StaticResource SettingsCardText}"
                                   Foreground="White"/>

                        <ContentControl Style="{DynamicResource TextboxLikeFrame}"
                                        Height="32"
                                        Background="{DynamicResource TextBox.Static.Background}"
                                        HorizontalAlignment="Stretch">
                            <Grid x:Name="PathBox" Style="{DynamicResource DisabledStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{DynamicResource BlankTextBox}"
                                         IsReadOnly="True"
                                         x:Name="StorageDirectoryTextBox"
                                         FontSize="14"
                                         Padding="10,4,5,3"/>
                                <Button Grid.Column="1"
                                        Content="{StaticResource GeneralSubtitles_Browse}"
                                        x:Name="BrowseDirectoryButton"
                                        Click="BrowseDirectoryButton_Click"
                                        Margin="5"
                                        Style="{StaticResource TextBoxButton}"/>
                                <Grid Grid.Column="2" Width="1" Background="Gray" Margin="2,5"/>
                                <Button Grid.Column="3"
                                        Content="{StaticResource GeneralSubtitles_Reset}"
                                        x:Name="ResetDirectoryButton"
                                        Click="ResetDirectoryButton_Click"
                                        Margin="5"
                                        Style="{StaticResource TextBoxButton}"/>
                            </Grid>
                        </ContentControl>

                        <TextBlock Margin="0,12,0,0"
                                   Text="{DynamicResource GeneralSettingsScreen_PathOptions_Notice_Text}"
                                   Style="{StaticResource SettingsCardText}"/>

                        <Button Margin="0,16,0,0"
                                Style="{DynamicResource DialogButton_Red}"
                                x:Name="RestartButton"
                                IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}"
                                Content="{DynamicResource GeneralSettingsScreen_PathOptions_RestartButton_Text}"
                                Height="32"
                                HorizontalAlignment="Left"
                                Click="RestartButton_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Backup tools" Style="{StaticResource SettingsCardTitle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="Create a quick backup of your save data before you change anything important."
                                   Style="{StaticResource SettingsCardText}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Style="{DynamicResource DialogButton_Green}"
                                    x:Name="BackupButton"
                                    IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}"
                                    Content="{DynamicResource GeneralSettingsScreen_BackupButton}"
                                    Height="32"
                                    Click="BackupButton_Click"/>
                            <Button Margin="10,0,0,0"
                                    Style="{DynamicResource DialogButton}"
                                    Content="Open Xylar Inc. Discord"
                                    Height="32"
                                    Click="OpenDiscordButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
