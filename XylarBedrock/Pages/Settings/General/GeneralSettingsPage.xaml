<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:properties="clr-namespace:XylarBedrock.Properties"
      xmlns:viewModels="clr-namespace:XylarBedrock.ViewModels"
      xmlns:con="clr-namespace:XylarBedrock.Pages.Settings.General.Components"
      x:Class="XylarBedrock.Pages.Settings.General.GeneralSettingsPage"
      mc:Ignorable="d"
      d:DesignHeight="828"
      d:DesignWidth="720"
      Title="GeneralSettingsPage"
      Loaded="Page_Loaded"
      Initialized="Page_Initialized"
      MinWidth="728"
      MinHeight="525"
      Background="{DynamicResource Background.Tertiary}">
    <Page.Resources>
        <Style x:Key="SectionBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Style>

        <Style x:Key="SectionText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Style>

        <Style x:Key="RowTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Style>

        <Style x:Key="RowText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFB9B9B9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource Background.Tertiary}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,22"
                        MaxWidth="1120"
                        HorizontalAlignment="Center">
                <Border BorderBrush="#FF484848"
                        BorderThickness="1"
                        Margin="0,0,0,16">
                    <Grid Height="168">
                        <Grid.Background>
                            <ImageBrush TileMode="Tile"
                                        Viewport="0,0,800,400"
                                        ViewportUnits="Absolute"
                                        ImageSource="/XylarBedrock;component/resources/images/bg/stone_texture.png"/>
                        </Grid.Background>

                        <Border Background="#C6141414"/>

                        <Grid Margin="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource GeneralSettingsPage_HeroTitle}"
                                           Foreground="White"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                                <TextBlock Margin="0,10,0,0"
                                           Text="{DynamicResource GeneralSettingsPage_HeroSubtitle}"
                                           Style="{StaticResource SectionText}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Right">
                                <Button Margin="0,0,0,8"
                                        Content="{DynamicResource GeneralSettingsPage_DiscordButton}"
                                        Click="OpenDiscordButton_Click"
                                        Style="{DynamicResource DialogButton_Green}"
                                        Height="32"/>
                                <Button Content="{DynamicResource GeneralSettingsPage_BackupNowButton}"
                                        Click="BackupButton_Click"
                                        Style="{DynamicResource DialogButton}"
                                        Height="32"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettingsPage_LauncherTitle}"
                                   Style="{StaticResource SectionTitle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{DynamicResource GeneralSettingsPage_LauncherText}"
                                   Style="{StaticResource SectionText}"/>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource GeneralSettingsScreen_LanguageSubtitle}"
                                           Style="{StaticResource RowTitle}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{DynamicResource GeneralSettingsPage_LanguageText}"
                                           Style="{StaticResource RowText}"/>
                            </StackPanel>

                            <con:LanguageCombobox Grid.Column="1"
                                                  x:Name="LanguageCombobox"
                                                  HorizontalAlignment="Stretch"
                                                  FontSize="14"
                                                  Padding="10,4,5,3"/>
                        </Grid>

                        <Border Height="1" Margin="0,16,0,16" Background="#FF3E3E3E"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource GeneralSettingsScreen_ThemeSubtitle}"
                                           Style="{StaticResource RowTitle}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{DynamicResource GeneralSettingsPage_ThemeText}"
                                           Style="{StaticResource RowText}"/>
                            </StackPanel>

                            <con:ThemeCombobox Grid.Column="1"
                                               x:Name="ThemeCombobox"
                                               HorizontalAlignment="Stretch"
                                               FontSize="14"
                                               Padding="10,4,5,3"/>
                        </Grid>

                        <Border Height="1" Margin="0,16,0,16" Background="#FF3E3E3E"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource GeneralSettingsScreen_KeepLauncherOpen}"
                                           Style="{StaticResource RowTitle}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{DynamicResource GeneralSettingsPage_KeepOpenText}"
                                           Style="{StaticResource RowText}"/>
                            </StackPanel>

                            <CheckBox x:Name="keepLauncherOpenCheckBox"
                                      Grid.Column="1"
                                      Style="{StaticResource SettingsCheckBox}"
                                      Content=""
                                      Click="Checkbox_Click"
                                      IsChecked="{Binding Source={x:Static properties:LauncherSettings.Default}, Path=KeepLauncherOpen}"
                                      IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}"/>
                        </Grid>

                        <Border Height="1" Margin="0,16,0,16" Background="#FF3E3E3E"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource GeneralSettingsScreen_AnimateTransitions}"
                                           Style="{StaticResource RowTitle}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{DynamicResource GeneralSettingsPage_AnimateText}"
                                           Style="{StaticResource RowText}"/>
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource SettingsCheckBox}"
                                      Content=""
                                      Click="Checkbox_Click"
                                      IsChecked="{Binding Source={x:Static properties:LauncherSettings.Default}, Path=AnimatePageTransitions}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource GeneralSettingsPage_StorageTitle}"
                                   Style="{StaticResource SectionTitle}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{DynamicResource GeneralSettingsPage_StorageText}"
                                   Style="{StaticResource SectionText}"/>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource GeneralSettingsScreen_PathOptions_PortableMode_Text}"
                                           Style="{StaticResource RowTitle}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{DynamicResource GeneralSettingsPage_PortableText}"
                                           Style="{StaticResource RowText}"/>
                            </StackPanel>

                            <CheckBox x:Name="portableModeCheckBox"
                                      Grid.Column="1"
                                      Style="{StaticResource SettingsCheckBox}"
                                      Content=""
                                      Click="useFixedInstallLocation_Click"/>
                        </Grid>

                        <Border Height="1" Margin="0,16,0,16" Background="#FF3E3E3E"/>

                        <TextBlock Text="{DynamicResource GeneralSettingsScreen_PathOptions_PathSubtitle_Text}"
                                   Style="{StaticResource RowTitle}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{DynamicResource GeneralSettingsPage_PathText}"
                                   Style="{StaticResource RowText}"/>

                        <ContentControl Style="{DynamicResource TextboxLikeFrame}"
                                        Height="34"
                                        Background="{DynamicResource TextBox.Static.Background}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,12,0,0">
                            <Grid x:Name="PathBox" Style="{DynamicResource DisabledStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="StorageDirectoryTextBox"
                                         Style="{DynamicResource BlankTextBox}"
                                         IsReadOnly="True"
                                         FontSize="14"
                                         Padding="10,4,5,3"/>

                                <Button Grid.Column="1"
                                        x:Name="BrowseDirectoryButton"
                                        Content="{StaticResource GeneralSubtitles_Browse}"
                                        Click="BrowseDirectoryButton_Click"
                                        Margin="5"
                                        Style="{StaticResource TextBoxButton}"/>

                                <Grid Grid.Column="2"
                                      Width="1"
                                      Background="Gray"
                                      Margin="2,5"/>

                                <Button Grid.Column="3"
                                        x:Name="ResetDirectoryButton"
                                        Content="{StaticResource GeneralSubtitles_Reset}"
                                        Click="ResetDirectoryButton_Click"
                                        Margin="5"
                                        Style="{StaticResource TextBoxButton}"/>
                            </Grid>
                        </ContentControl>

                        <TextBlock Margin="0,12,0,0"
                                   Text="{DynamicResource GeneralSettingsScreen_PathOptions_Notice_Text}"
                                   Style="{StaticResource RowText}"/>

                        <Button x:Name="RestartButton"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Left"
                                Height="32"
                                Content="{DynamicResource GeneralSettingsScreen_PathOptions_RestartButton_Text}"
                                Click="RestartButton_Click"
                                Style="{DynamicResource DialogButton_Red}"
                                IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{DynamicResource GeneralSettingsPage_HelpTitle}"
                                       Style="{StaticResource SectionTitle}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{DynamicResource GeneralSettingsPage_HelpText}"
                                       Style="{StaticResource SectionText}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{DynamicResource GeneralSettingsPage_RuntimeText}"
                                       Style="{StaticResource RowText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BackupButton"
                                    Height="32"
                                    Content="{DynamicResource GeneralSettingsScreen_BackupButton}"
                                    Click="BackupButton_Click"
                                    Style="{DynamicResource DialogButton_Green}"
                                    IsEnabled="{Binding Source={x:Static viewModels:MainDataModel.Default}, Path=ProgressBarState.AllowEditing, Mode=OneWay}"/>
                            <Button Margin="10,0,0,0"
                                    Height="32"
                                    Content="{DynamicResource GeneralSettingsPage_OpenDiscordButton}"
                                    Click="OpenDiscordButton_Click"
                                    Style="{DynamicResource DialogButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
