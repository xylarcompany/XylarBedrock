<Page x:Class="XylarBedrock.Pages.Play.FAQ.FaqPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="525"
      d:DesignWidth="828"
      Title="FaqPage"
      Background="{DynamicResource Background.Tertiary}">
    <Page.Resources>
        <Style x:Key="FaqCardBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
        </Style>

        <Style x:Key="FaqBadge" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#FF151515"/>
            <Setter Property="BorderBrush" Value="#FF4E4E4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="FaqQuestionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FaqAnswerText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFD0D0D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource Background.Tertiary}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,18,18,22"
                        MaxWidth="1080"
                        HorizontalAlignment="Center">
                <Border BorderBrush="#FF484848"
                        BorderThickness="1"
                        Margin="0,0,0,16">
                    <Grid Height="196">
                        <Grid.Background>
                            <ImageBrush TileMode="Tile"
                                        Viewport="0,0,800,400"
                                        ViewportUnits="Absolute"
                                        ImageSource="/XylarBedrock;component/resources/images/bg/stone_texture.png"/>
                        </Grid.Background>
                        <Border Background="#C6141414"/>
                        <Grid Margin="22">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource FaqPage_Title}"
                                           Foreground="White"
                                           FontSize="32"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                                <TextBlock Margin="0,10,0,0"
                                           Text="{DynamicResource FaqPage_Subtitle}"
                                           Foreground="#FFE0E0E0"
                                           FontSize="14"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource FaqCardBorder}">
                        <StackPanel>
                            <Border Style="{StaticResource FaqBadge}" HorizontalAlignment="Left">
                                <TextBlock Text="01"
                                           Foreground="#FFFFE17C"
                                           FontSize="12"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource FaqPage_Q1_Title}"
                                       Style="{StaticResource FaqQuestionTitle}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{DynamicResource FaqPage_Q1_Text}"
                                       Style="{StaticResource FaqAnswerText}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource FaqCardBorder}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <Border Style="{StaticResource FaqBadge}" HorizontalAlignment="Left">
                                <TextBlock Text="02"
                                           Foreground="#FFFFE17C"
                                           FontSize="12"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource FaqPage_Q2_Title}"
                                       Style="{StaticResource FaqQuestionTitle}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{DynamicResource FaqPage_Q2_Text}"
                                       Style="{StaticResource FaqAnswerText}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Style="{StaticResource FaqCardBorder}">
                        <StackPanel>
                            <Border Style="{StaticResource FaqBadge}" HorizontalAlignment="Left">
                                <TextBlock Text="03"
                                           Foreground="#FFFFE17C"
                                           FontSize="12"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource FaqPage_Q3_Title}"
                                       Style="{StaticResource FaqQuestionTitle}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{DynamicResource FaqPage_Q3_Text}"
                                       Style="{StaticResource FaqAnswerText}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource FaqCardBorder}"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <Border Style="{StaticResource FaqBadge}" HorizontalAlignment="Left">
                                <TextBlock Text="04"
                                           Foreground="#FFFFE17C"
                                           FontSize="12"
                                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"/>
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       Text="{DynamicResource FaqPage_Q4_Title}"
                                       Style="{StaticResource FaqQuestionTitle}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{DynamicResource FaqPage_Q4_Text}"
                                       Style="{StaticResource FaqAnswerText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
