<Page x:Class="XylarBedrock.Pages.Welcome.WelcomePageThree"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:XylarBedrock.Pages.Welcome"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePageOne">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="30,28,30,0">
            <TextBlock HorizontalAlignment="Left"
                       Text="Set up your profile"
                       Foreground="White"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                       FontSize="28"/>
            <TextBlock Margin="0,12,0,0"
                       HorizontalAlignment="Left"
                       Foreground="#FFE0E0E0"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Text="Choose the name and profile picture you want to use inside XylarBedrock. If you already had a profile, you can update it here before finishing the setup."/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="30,24,30,22"
                Background="#FF1F1F1F"
                BorderBrush="#FF101010"
                BorderThickness="2"
                Padding="14,8,14,8">
            <Grid x:Name="ProfileControlHost"/>
        </Border>
    </Grid>
</Page>
