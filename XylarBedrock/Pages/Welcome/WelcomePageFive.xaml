<Page x:Class="XylarBedrock.Pages.Welcome.WelcomePageFive"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:XylarBedrock.Pages.Welcome"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePageOne">
    <Grid Margin="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="30,28,30,0">
            <TextBlock HorizontalAlignment="Left"
                       Text="{DynamicResource FirstLaunch_AlmostThereTitle}"
                       Foreground="White"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                       FontSize="28"/>
            <TextBlock Margin="0,12,0,0"
                       HorizontalAlignment="Left"
                       Text="{DynamicResource FirstLaunch_BeforeStartingToUse}"
                       Foreground="#FFE0E0E0"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="30,24,30,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Margin="0,0,10,0"
                    Background="#FF1F1F1F"
                    BorderBrush="#FF101010"
                    BorderThickness="2"
                    Padding="18,16,18,16">
                <StackPanel>
                    <TextBlock Text="What happens next"
                               Foreground="White"
                               FontSize="18"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#FFD7D7D7"
                               FontSize="13"
                               TextWrapping="Wrap"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               Text="The launcher saves your setup, checks the Store version of Minecraft for Windows, and keeps your main files ready so you can jump in without doing this again."/>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#FFC9D7E7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               Text="The copyright warning still shows on every launch, but this setup wizard only appears once."/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="#FF1F1F1F"
                    BorderBrush="#FF101010"
                    BorderThickness="2"
                    Padding="18,16,18,16">
                <CheckBox x:Name="BackupCheckbox"
                          IsChecked="True"
                          Foreground="White"
                          VerticalAlignment="Top">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource FirstLaunch_BackupCheckBox_Text}"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                                   Foreground="White"
                                   FontSize="16"/>
                        <TextBlock Margin="0,10,0,0"
                                   Text="{DynamicResource FirstLaunch_BackupCheckBox_Subtext}"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                                   Foreground="#FFD7D7D7"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FF171717"
                BorderBrush="#FF0E0E0E"
                BorderThickness="0,2,0,0">
            <StackPanel Margin="0,0,12,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <Button x:Name="BackButton" Click="BackButton_Click" SnapsToDevicePixels="True" Foreground="White" Content="{DynamicResource FirstLaunch_BackButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="32" Style="{DynamicResource DialogButton}"/>
                <Button x:Name="NextButton" Click="NextButton_Click" SnapsToDevicePixels="True" Foreground="White" Content="{DynamicResource FirstLaunch_FinishButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="auto" Height="32" Style="{DynamicResource DialogButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
