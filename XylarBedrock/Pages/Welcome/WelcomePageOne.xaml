<Page x:Class="XylarBedrock.Pages.Welcome.WelcomePageOne"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:XylarBedrock.Pages.Welcome"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePageOne">
    <Grid Margin="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="30,28,30,0">
            <TextBlock HorizontalAlignment="Left"
                       Text="Before you start"
                       Foreground="White"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                       FontSize="30"/>
            <TextBlock Margin="0,14,0,0"
                       Foreground="#FFE2E2E2"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                       FontSize="14"
                       TextWrapping="Wrap">
                XylarBedrock works only with the original Minecraft for Windows app from Microsoft Store. Install Minecraft for Windows first, even with the free trial, then come back here.
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="30,24,30,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Margin="0,0,10,0"
                    Background="#FF1F1F1F"
                    BorderBrush="#FF101010"
                    BorderThickness="2"
                    Padding="18,16,18,16">
                <StackPanel>
                    <TextBlock Text="Minecraft for Windows"
                               Foreground="White"
                               FontSize="18"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#FFD8D8D8"
                               FontSize="13"
                               TextWrapping="Wrap"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               Text="The launcher checks for the real Microsoft Store version. That keeps installs clean and makes the setup way less annoying later."/>
                    <Border Margin="0,16,0,0"
                            Background="#FF2B2B2B"
                            BorderBrush="#FF151515"
                            BorderThickness="1"
                            Padding="10,8,10,8">
                        <TextBlock Foreground="#FFF2D35A"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"
                                   Text="Free trial works too."/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Background="#FF1F1F1F"
                    BorderBrush="#FF101010"
                    BorderThickness="2"
                    Padding="18,16,18,16">
                <StackPanel>
                    <TextBlock Text="Automatic checkup"
                               Foreground="White"
                               FontSize="18"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Minecraft Ten"/>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#FFD8D8D8"
                               FontSize="13"
                               TextWrapping="Wrap"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               Text="If Microsoft Visual C++ x64 Runtime is missing, XylarBedrock will try the official Microsoft install for you when it starts."/>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#FFC9D7E7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                               Text="Use the Store button if you want to jump straight to the official page."/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FF171717"
                BorderBrush="#FF0E0E0E"
                BorderThickness="0,2,0,0">
            <StackPanel Margin="0,0,12,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <Button x:Name="OpenStoreButton" Click="OpenStoreButton_Click" SnapsToDevicePixels="True" Foreground="White" Style="{DynamicResource DialogButton_Green}" Content="Open Microsoft Store" HorizontalAlignment="Left" VerticalAlignment="Top" Height="32"/>
                <Button x:Name="CloseButton" Click="CloseButton_Click" SnapsToDevicePixels="True" Foreground="White" Style="{DynamicResource DialogButton}" Content="{DynamicResource FirstLaunch_CloseButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="32"/>
                <Button x:Name="NextButton" Click="NextButton_Click" SnapsToDevicePixels="True" Style="{DynamicResource DialogButton}" Foreground="White" Content="{DynamicResource FirstLaunch_NextButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="auto" Height="32"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
