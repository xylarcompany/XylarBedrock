<Page x:Class="XylarBedrock.Pages.Welcome.WelcomePageOne"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:XylarBedrock.Pages.Welcome"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePageOne" Width="596" Height="254">
    <Grid Margin="0" Background="{x:Null}">
        <Border Background="#FF313131" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,55" />
        <StackPanel VerticalAlignment="Top" Margin="28,28,28,0">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Text="Before you start"
                       Foreground="White"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock HorizontalAlignment="Center"
                       TextAlignment="Center"
                       VerticalAlignment="Top"
                       Foreground="White"
                       FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                       FontSize="14"
                       Margin="0,16,0,0"
                       TextWrapping="Wrap">
                XylarBedrock works only with the original Minecraft for Windows app from Microsoft Store.
                Install Minecraft for Windows first, even with the free trial, then come back here.
            </TextBlock>

            <Border Margin="0,18,0,0"
                    Background="#161D23"
                    BorderBrush="#2D3D4C"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <TextBlock Text="Need it now? Use the button below to open the official Microsoft Store page directly."
                           Foreground="#BFD3E2"
                           FontFamily="/XylarBedrock;component/Resources/fonts/#Noto Sans"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
        <StackPanel Margin="0,0,8,8" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <Button x:Name="OpenStoreButton" Click="OpenStoreButton_Click" SnapsToDevicePixels="True" Foreground="White" Style="{DynamicResource DialogButton_Green}" Content="Open Microsoft Store" HorizontalAlignment="Left" VerticalAlignment="Top" Height="32"/>
            <Button x:Name="CloseButton" Click="CloseButton_Click" SnapsToDevicePixels="True" Foreground="White" Style="{DynamicResource DialogButton}" Content="{DynamicResource FirstLaunch_CloseButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Height="32"/>
            <Button x:Name="NextButton" Click="NextButton_Click" SnapsToDevicePixels="True" Style="{DynamicResource DialogButton}" Foreground="White" Content="{DynamicResource FirstLaunch_NextButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="auto" Height="32"/>
        </StackPanel>
    </Grid>
</Page>

